#!/usr/bin/env bash

MIC="@DEFAULT_AUDIO_SOURCE@"

wpctl set-mute "$MIC" toggle

if wpctl get-volume "$MIC" | grep -q MUTED; then
    pw-play ~/Audio/Notification/off.oga &
    notify-send "Microphone" "Muted" -r 69420 &
else
    pw-play ~/Audio/Notification/on.oga &
    notify-send "Microphone" "Unmuted" -r 69420 &
fi
